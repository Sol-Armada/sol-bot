# MongoDB Connection Settings
# Priority: Environment variables > TOML files > defaults

# MongoDB Host (default: localhost)
MONGO_HOST=localhost

# MongoDB Port (default: 27017)
MONGO_PORT=27017

# MongoDB Username (optional)
MONGO_USERNAME=

# MongoDB Password (optional, @ symbols will be automatically URL encoded)
MONGO_PASSWORD=

# MongoDB Database Name (default: org)
MONGO_DATABASE=solarmada

# MongoDB Replica Set Name (optional)
MONGO_REPLICA_SET_NAME=

# Logger settings
DEBUG=false
LOG_CLI=false
LOG_FILE=solbot.log
LOG_PATH=./logs
