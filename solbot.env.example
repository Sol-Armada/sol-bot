# Copy to /etc/solbot/solbot.env and adjust values.
# This file is read by systemd via EnvironmentFile.

# Runtime environment label (used for logs/telemetry)
APP_ENV=prod

# Optional: explicit config file path. If omitted, loader checks:
# /etc/solbot/config.toml, ./settings.toml, ../settings.toml
SOLBOT_CONFIG_FILE=/etc/solbot/config.toml

# Postgres settings (override file values)
SOLBOT_POSTGRES_HOST=127.0.0.1
SOLBOT_POSTGRES_PORT=5432
SOLBOT_POSTGRES_USERNAME=solbot
SOLBOT_POSTGRES_PASSWORD=replace_me
SOLBOT_POSTGRES_DATABASE=solarmada
SOLBOT_POSTGRES_SSL_MODE=disable
SOLBOT_POSTGRES_MAX_CONNS=10
SOLBOT_POSTGRES_MIN_CONNS=1
SOLBOT_POSTGRES_CONNECT_TIMEOUT=5s

# Secrets often set via env in production
# SOLBOT_DISCORD_BOT_TOKEN=
# SOLBOT_DISCORD_CLIENT_SECRET=
