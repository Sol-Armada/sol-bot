# Copy to /etc/solbot/solbot.env and adjust values.
# This file is read by systemd via EnvironmentFile.

# Runtime environment label (used for logs/telemetry)
APP_ENV=prod

# Leave this commented for env-only configuration.
# SOLBOT_CONFIG_FILE=/etc/solbot/config.toml

# General settings
SOLBOT_ALLIES=
SOLBOT_ALLY_ROLE=
SOLBOT_ENEMIES=
SOLBOT_RSI_ORG_SID=
SOLBOT_LOGO=
SOLBOT_PROMOTIONS_CHANNEL_ID=

# Logging: JSON output to stdout, captured by journald for centralized collection.
# LOG_FILE is unused in production; logs go to journald via stdout.
SOLBOT_LOG_DEBUG=false
SOLBOT_LOG_CLI=false

# Data store
SOLBOT_POSTGRES_HOST=127.0.0.1
SOLBOT_POSTGRES_PORT=5432
SOLBOT_POSTGRES_USERNAME=postgres
SOLBOT_POSTGRES_PASSWORD=
SOLBOT_POSTGRES_DATABASE=solbot
SOLBOT_POSTGRES_SSL_MODE=disable
SOLBOT_POSTGRES_MAX_CONNS=10
SOLBOT_POSTGRES_MIN_CONNS=1
SOLBOT_POSTGRES_CONNECT_TIMEOUT=5s

# Discord
SOLBOT_DISCORD_CLIENT_ID=
SOLBOT_DISCORD_BOT_TOKEN=
SOLBOT_DISCORD_GUILD_ID=
SOLBOT_DISCORD_ERROR_CHANNEL_ID=

# Role IDs used in code paths today
SOLBOT_DISCORD_ROLE_IDS_ADMIRAL=
SOLBOT_DISCORD_ROLE_IDS_COMMANDER=
SOLBOT_DISCORD_ROLE_IDS_LIEUTENANT=
SOLBOT_DISCORD_ROLE_IDS_SPECIALIST=
SOLBOT_DISCORD_ROLE_IDS_TECHNICIAN=
SOLBOT_DISCORD_ROLE_IDS_MEMBER=
SOLBOT_DISCORD_ROLE_IDS_AFFILIATE=
SOLBOT_DISCORD_ROLE_IDS_RECRUIT=
SOLBOT_DISCORD_ROLE_IDS_ALLY=

# Legacy rank-role path still referenced in on_role_change
SOLBOT_DISCORD_ROLES_RANKS_MEMBER=

# Features
SOLBOT_FEATURES_MONITOR_ENABLE=false
SOLBOT_FEATURES_SYSTEMD_ENABLE=true

SOLBOT_FEATURES_MERIT_ENABLE=false

SOLBOT_FEATURES_ATTENDANCE_ENABLE=true
SOLBOT_FEATURES_ATTENDANCE_CHANNEL_ID=
SOLBOT_FEATURES_ATTENDANCE_ALLOWED_ROLES=,

SOLBOT_FEATURES_ONBOARDING_ENABLE=true
SOLBOT_FEATURES_ONBOARDING_INPUT_CHANNEL_ID=
SOLBOT_FEATURES_ONBOARDING_OUTPUT_CHANNEL_ID=

SOLBOT_FEATURES_ACTIVITY_TRACKING_ENABLE=false
SOLBOT_FEATURES_ACTIVITY_TRACKING_AFK_CHANNEL_ID=

SOLBOT_FEATURES_TOKENS_ENABLE=true
SOLBOT_FEATURES_TOKENS_ALLOWED_ROLES=,

SOLBOT_FEATURES_RAFFLES_ENABLE=true
SOLBOT_FEATURES_RAFFLES_ALLOWED_ROLES=,

SOLBOT_FEATURES_GIVEAWAYS_ENABLE=true
SOLBOT_FEATURES_GIVEAWAYS_ALLOWED_ROLES=,

# RSI integration
SOLBOT_RSI_TOKEN=
