# Repository to poll for new tagged releases.
REPO_OWNER=Sol-Armada
REPO_NAME=sol-bot

# Runtime installation settings.
APP_NAME=solbot
SERVICE_NAME=solbot
ARCH=amd64
INSTALL_PATH=/opt/solbot
RELEASES_DIR=/opt/solbot-releases
STATE_DIR=/var/lib/solbot

# Optional: token for private repos / higher API rate limits.
# Keep this file mode 0600 if token is used.
GH_TOKEN=
